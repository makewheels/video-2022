# video-2022 AI Agent 环境变量
# 复制此文件为 .env 并填入实际值
# .env 文件不会被提交到 Git

# LLM 供应商: minimax | deepseek | openai | moonshot | ...
VIDEO_AGENT_LLM_PROVIDER=minimax

# LLM API 配置
VIDEO_AGENT_LLM_API_KEY=your-api-key-here
VIDEO_AGENT_LLM_BASE_URL=https://api.minimaxi.com/v1
VIDEO_AGENT_LLM_MODEL=MiniMax-M2.7

# 工具后端: fixture（离线测试）| cli（真实后端）
VIDEO_AGENT_BACKEND=fixture

# 真实后端配置（仅 backend=cli 时需要）
VIDEO_CLI_BASE_URL=http://localhost:5022
VIDEO_CLI_TOKEN=

# 写操作确认（1=true, 0=false）
VIDEO_AGENT_CONFIRM_WRITE=0
